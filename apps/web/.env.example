# =============================================================================
# ACOS Web Application — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# NEVER commit .env.local or any file containing real credentials
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Database, Auth & Storage
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
# -----------------------------------------------------------------------------

# [REQUIRED] Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# [REQUIRED] Supabase anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# [REQUIRED] Supabase service role key (NEVER expose in browser — server-only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# [REQUIRED] JWT secret from Supabase → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-super-secret-jwt-string-minimum-32-chars

# [OPTIONAL] Direct database URL for Drizzle ORM migrations (uses connection pooling)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# [OPTIONAL] Direct database URL (non-pooled — for migrations only)
DATABASE_URL_UNPOOLED=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# AI — Language Models
# -----------------------------------------------------------------------------

# [REQUIRED] OpenAI API key — for GPT-4o
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# [REQUIRED] Anthropic API key — for Claude 3.5 Sonnet
# Get from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# [REQUIRED] Google AI API key — for Gemini 2.0 Flash
# Get from: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIzaSy...

# [OPTIONAL] OpenAI organization ID (if using organization account)
OPENAI_ORGANIZATION_ID=org-...

# [OPTIONAL] Default AI model to use (openai | anthropic | google)
AI_DEFAULT_PROVIDER=openai

# [OPTIONAL] Maximum tokens for AI responses
AI_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Automation — n8n Webhooks
# -----------------------------------------------------------------------------

# [REQUIRED] Base URL of your n8n instance
N8N_WEBHOOK_URL=https://n8n.aquacolloids.com

# [REQUIRED] Shared secret for n8n webhook authentication
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-min-32-chars

# [OPTIONAL] n8n API key for programmatic workflow management
N8N_API_KEY=your-n8n-api-key

# -----------------------------------------------------------------------------
# Email — Resend
# Get from: https://resend.com/api-keys
# -----------------------------------------------------------------------------

# [REQUIRED] Resend API key for transactional email
RESEND_API_KEY=re_...

# [OPTIONAL] Default from address for transactional emails
RESEND_FROM_EMAIL=noreply@aquacolloids.com

# [OPTIONAL] Default from name for transactional emails
RESEND_FROM_NAME=Aqua Colloids ACOS

# -----------------------------------------------------------------------------
# Analytics & Monitoring
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable Vercel Analytics (set to "true" to enable)
NEXT_PUBLIC_VERCEL_ANALYTICS=true

# [OPTIONAL] Vercel Speed Insights
NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS=true

# [OPTIONAL] Sentry DSN for error tracking
SENTRY_DSN=https://...@o....ingest.sentry.io/...

# [OPTIONAL] Sentry auth token for source map upload during builds
SENTRY_AUTH_TOKEN=sntrys_...

# [OPTIONAL] Sentry organization slug
SENTRY_ORG=aquagri

# [OPTIONAL] Sentry project slug
SENTRY_PROJECT=acos-web

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# [REQUIRED] Full URL of the application (no trailing slash)
# Local: http://localhost:3000
# Staging: https://acos-staging.vercel.app
# Production: https://acos.aquacolloids.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED] Application display name
NEXT_PUBLIC_APP_NAME=ACOS

# [REQUIRED] Application version (sync with package.json)
NEXT_PUBLIC_APP_VERSION=1.0.0

# [OPTIONAL] Application environment (development | staging | production)
NEXT_PUBLIC_APP_ENV=development

# [OPTIONAL] Feature flag: Enable AI assistant across the platform
NEXT_PUBLIC_FEATURE_AI=true

# [OPTIONAL] Feature flag: Enable LinkedIn intelligence module
NEXT_PUBLIC_FEATURE_LINKEDIN=true

# [OPTIONAL] Feature flag: Enable advanced analytics
NEXT_PUBLIC_FEATURE_ANALYTICS=true

# [OPTIONAL] Feature flag: Enable operations module
NEXT_PUBLIC_FEATURE_OPERATIONS=false

# [OPTIONAL] Feature flag: Enable CMS module
NEXT_PUBLIC_FEATURE_CMS=false

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# [OPTIONAL] Supabase Storage bucket for document uploads
STORAGE_BUCKET_DOCUMENTS=documents

# [OPTIONAL] Supabase Storage bucket for brand assets
STORAGE_BUCKET_ASSETS=brand-assets

# [OPTIONAL] Supabase Storage bucket for COA documents
STORAGE_BUCKET_COA=certificates

# [OPTIONAL] Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE_BYTES=52428800

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# [OPTIONAL] CSRF secret key (min 32 chars)
CSRF_SECRET=your-csrf-secret-key-minimum-32-characters

# [OPTIONAL] Encryption key for sensitive data at rest (32 hex chars)
ENCRYPTION_KEY=your-32-character-hex-encryption-key-here

# [OPTIONAL] Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://acos.aquacolloids.com

# -----------------------------------------------------------------------------
# Integrations (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] IndiaMart Lead API key
INDIAMART_API_KEY=your-indiamart-api-key

# [OPTIONAL] LinkedIn API credentials (for LinkedIn intelligence module)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# [OPTIONAL] Zoho CRM credentials (for migration/integration)
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# [OPTIONAL] WhatsApp Business API (for notifications)
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# =============================================================================
# END OF .env.example
# =============================================================================
