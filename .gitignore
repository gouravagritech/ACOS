# =============================================================================
# ACOS Monorepo — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Node / pnpm
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
.next/
out/
build/
dist/

# ---------------------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# ---------------------------------------------------------------------------
# Environment variables (NEVER commit these)
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging
.env.production
.env.*.local
!.env.example

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
supabase/.branches/
supabase/.temp/
supabase/functions/node_modules/
.supabase/

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
n8n/.env
n8n/data/
n8n/logs/
n8n/.n8n/

# ---------------------------------------------------------------------------
# Turbo
# ---------------------------------------------------------------------------
.turbo/
.cache/

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.vitest/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.DS_Store

# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
*.log.*

# ---------------------------------------------------------------------------
# Generated / Build artifacts
# ---------------------------------------------------------------------------
storybook-static/
.docusaurus/
*.tgz
*.tar.gz

# ---------------------------------------------------------------------------
# Drizzle ORM
# ---------------------------------------------------------------------------
drizzle/
.drizzle/

# ---------------------------------------------------------------------------
# Vercel
# ---------------------------------------------------------------------------
.vercel/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock
*.pem
*.p12
*.key
*.crt
*.cer
tmp/
temp/
